{% macro render_params(params) -%}
{%- for param in params -%}
{{ param.name }}: {{ param.type }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
{%- endmacro %}

{% macro render_class(spec) -%}
class {{ spec.name }}:
    def __init__({% if spec.params %}self, {{ render_params(spec.params) }}{% else %}self{% endif %}) -> None:
{% if spec.params %}
{% for param in spec.params %}
        self.{{ param.name }} = {{ param.name }}
{% endfor %}
{% else %}
        pass
{% endif %}

{% endmacro %}

{% macro render_typed_dict(spec) -%}
class {{ spec.name }}(TypedDict):
{% if spec.fields %}
{% for field in spec.fields %}
    {{ field.name }}: {{ field.type }}
{% endfor %}
{% else %}
    pass
{% endif %}

{% endmacro %}

{% macro render_method(method) -%}
def {{ method.name }}({% if method.params %}self, {{ render_params(method.params) }}{% else %}self{% endif %}) -> {{ method.return_type }}: ...
{%- endmacro %}

{% macro render_protocol(spec) -%}
class {{ spec.name }}(Protocol):
{% if spec.fields or spec.methods %}
{% for field in spec.fields %}
    {{ field.name }}: {{ field.type }}
{% endfor %}
{% for method in spec.methods %}
    {{ render_method(method) }}
{% endfor %}
{% else %}
    pass
{% endif %}

{% endmacro %}

{% macro render_function(spec) -%}
def {{ spec.name }}({{ render_params(spec.params) }}) -> {{ spec.return_type }}:
{% for line in spec.body %}
    {{ line }}
{% endfor %}

{% endmacro %}

{% macro render_hook(spec) -%}
def {{ spec.function_name }}({{ render_params(spec.params) }}) -> None:
    return None

{% endmacro %}

from typing import Annotated, Protocol, TypedDict

from inlay import LazyRef, RegistryBuilder, qual

{% for spec in class_specs %}
{{ render_class(spec) }}
{% endfor %}

{% for spec in typed_dict_specs %}
{{ render_typed_dict(spec) }}
{% endfor %}

{% for spec in protocol_specs %}
{{ render_protocol(spec) }}
{% endfor %}

{% for spec in function_specs %}
{{ render_function(spec) }}
{% endfor %}

{% for spec in root_hooks %}
{{ render_hook(spec) }}
{% endfor %}

{% for module_registry in registries %}
{% for spec in module_registry.hooks %}
{{ render_hook(spec) }}
{% endfor %}
{% endfor %}

def build_registry() -> RegistryBuilder:
    registry = RegistryBuilder()
    shared_registry = RegistryBuilder()
{% for class_name in global_classes %}
    shared_registry = shared_registry.register({{ class_name }})({{ class_name }})
{% endfor %}
    registry = registry.include(shared_registry)
{% for method in root_methods %}
    registry = registry.register_method({{ method.protocol_name }}, method_name='{{ method.method_name }}')({{ method.function_name }})
{% endfor %}
{% for registration in root_constructor_registrations %}
    registry = registry.register({{ registration.type_name }}, qualifiers={{ registration.qualifiers }})({{ registration.provider_name }})
{% endfor %}
{% for hook in root_hooks %}
    registry = registry.register_method_hook({{ hook.protocol_name }}, method_name='{{ hook.method_name }}')({{ hook.function_name }})
{% endfor %}

{% for module_registry in registries %}
    {{ module_registry.module.name }}_common = RegistryBuilder().include(shared_registry)
{% for class_name in module_registry.common_classes %}
    {{ module_registry.module.name }}_common = {{ module_registry.module.name }}_common.register({{ class_name }})({{ class_name }})
{% endfor %}
{% for method in module_registry.methods %}
    {{ module_registry.module.name }}_common = {{ module_registry.module.name }}_common.register_method({{ method.protocol_name }}, method_name='{{ method.method_name }}')({{ method.function_name }})
{% endfor %}
{% for hook in module_registry.hooks %}
    {{ module_registry.module.name }}_common = {{ module_registry.module.name }}_common.register_method_hook({{ hook.protocol_name }}, method_name='{{ hook.method_name }}')({{ hook.function_name }})
{% endfor %}

    {{ module_registry.module.name }}_write = RegistryBuilder().include({{ module_registry.module.name }}_common)
{% for class_name in module_registry.write_classes %}
    {{ module_registry.module.name }}_write = {{ module_registry.module.name }}_write.register({{ class_name }})({{ class_name }})
{% endfor %}

    registry = registry.include({{ module_registry.module.name }}_write, qualifiers=qual('{{ module_registry.module.name }}') & qual('write'))
    registry = registry.include({{ module_registry.module.name }}_common, qualifiers=qual('{{ module_registry.module.name }}'))

{% endfor %}
    return registry


REGISTRY = build_registry().build()
