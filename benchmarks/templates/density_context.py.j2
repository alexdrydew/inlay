def build_registry() -> RegistryBuilder:
    shared_registry = (
        RegistryBuilder()
        .register(BaseShared)(BaseShared)
        .register(BranchShared)(BranchShared)
        .register(HookShared)(HookShared)
    )

    story_registry = (
        RegistryBuilder()
        .include(shared_registry)
        .register(StoryModuleState)(StoryModuleState)
        .register(StoryBase)(StoryBase)
    )

    character_registry = (
        RegistryBuilder()
        .include(shared_registry)
        .register(CharacterModuleState)(CharacterModuleState)
        .register(CharacterBase)(CharacterBase)
    )

    chat_registry = (
        RegistryBuilder()
        .include(shared_registry)
        .register(ChatModuleState)(ChatModuleState)
        .register(ChatEntryMarker)(ChatEntryMarker)
        .register(ChatBase)(ChatBase)
        .register(ChatSessionService)(ChatSessionService)
        .register(ChatBranchExecutor)(ChatBranchExecutor)
        .register(ChatBranchToken)(ChatBranchToken)
        .register(ChatBranchService)(ChatBranchService)
{% for index in range(density) %}
        .register_method(ChatContext, method_name='entry_{{ index }}')(chat_entry_{{ index }})
{% endfor %}
    )

    registry = (
        RegistryBuilder()
        .include(shared_registry)
        .register_method(AppContext, method_name='with_chat_context')(app_with_chat_context)
        .register_method(AppContext, method_name='with_story_context')(app_with_story_context)
        .register_method(AppContext, method_name='with_character_context')(app_with_character_context)
{% for index in range(query_repeats) %}
        .register(ChatStoryQuery{{ index }}, qualifiers=qual('chat'))(provide_chat_story_query_{{ index }})
        .register(ChatCharacterQuery{{ index }}, qualifiers=qual('chat'))(provide_chat_character_query_{{ index }})
{% endfor %}
    )

{% for hook_index in range(hook_fanout) %}
    registry = registry.register_method_hook(AppContext, method_name='with_chat_context')(app_with_chat_context_hook_{{ hook_index }})
    registry = registry.register_method_hook(AppContext, method_name='with_story_context')(app_with_story_context_hook_{{ hook_index }})
    registry = registry.register_method_hook(AppContext, method_name='with_character_context')(app_with_character_context_hook_{{ hook_index }})
{% for index in range(density) %}
    chat_registry = chat_registry.register_method_hook(ChatContext, method_name='entry_{{ index }}')(chat_entry_{{ index }}_hook_{{ hook_index }})
{% endfor %}
{% endfor %}
    registry = registry.include(chat_registry, qualifiers=qual('chat'))
    registry = registry.include(story_registry, qualifiers=qual('story'))
    registry = registry.include(character_registry, qualifiers=qual('character'))
    return registry


REGISTRY = build_registry().build()
