def build_registry() -> RegistryBuilder:
    registry = RegistryBuilder()
    shared_registry = RegistryBuilder()
{% for slot in shared_slot_indices %}
    shared_registry = shared_registry.register(BaseShared{{ slot }})(BaseShared{{ slot }})
    shared_registry = shared_registry.register(EntryShared{{ slot }})(EntryShared{{ slot }})
    shared_registry = shared_registry.register(ScopeShared{{ slot }})(ScopeShared{{ slot }})
    shared_registry = shared_registry.register(EventShared{{ slot }})(EventShared{{ slot }})
    shared_registry = shared_registry.register(HookShared{{ slot }})(HookShared{{ slot }})
{% endfor %}
    registry = registry.include(shared_registry)
{% for module in active_modules %}
    registry = registry.register_method(AppContext, AppContext.with_{{ module.name }}_context)(app_with_{{ module.name }}_context)
{% endfor %}
{% for module in active_modules %}
    registry = registry.register_alias(Annotated[int, qual('{{ module.name }}') & qual('write')])(Annotated[int, qual('{{ module.name }}')])
    registry = registry.register_alias(Annotated[str, qual('{{ module.name }}') & qual('write')])(Annotated[str, qual('{{ module.name }}')])
{% endfor %}
{% for module in active_modules %}
{% if module.extra_transition == 'flow' %}
    registry = registry.register(BetaDeltaQueries, qualifiers={{ module_scopes('beta') }})(provide_beta_delta_queries)
    registry = registry.register(BetaEpsilonData, qualifiers={{ module_scopes('beta') }})(provide_beta_epsilon_data)
{% elif module.extra_transition == 'worker' %}
    registry = registry.register(GammaAlphaQueries, qualifiers={{ module_scopes('gamma') }})(provide_gamma_alpha_queries)
    registry = registry.register(GammaDeltaQueries, qualifiers={{ module_scopes('gamma') }})(provide_gamma_delta_queries)
    registry = registry.register(GammaEpsilonQueries, qualifiers={{ module_scopes('gamma') }})(provide_gamma_epsilon_queries)
{% endif %}
{% endfor %}
{% for module in active_modules %}
{% for hook in range(density) %}
    registry = registry.register_method(AppContext, AppContext.with_{{ module.name }}_context)(app_with_{{ module.name }}_context_hook_{{ hook }})
{% endfor %}
{% endfor %}

{% for module in active_modules %}
{% set title = module.title %}
    {{ module.name }}_common = RegistryBuilder().include(shared_registry)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}ModuleState)({{ title }}ModuleState)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}WriteState)({{ title }}WriteState)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}BaseService)({{ title }}BaseService)
{% if module.kind in ['entry', 'scope'] %}
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}HandlerState)({{ title }}HandlerState)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}ScopeState)({{ title }}ScopeState)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}EventState)({{ title }}EventState)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}TransactionExecutor)({{ title }}TransactionExecutor)
{% for handler in range(handler_count) %}
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}Handler{{ handler }})({{ title }}Handler{{ handler }})
{% endfor %}
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}HandlerRefs)({{ title }}HandlerRefs)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}ScopeAudit)({{ title }}ScopeAudit)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}ScopeService)({{ title }}ScopeService)
    {{ module.name }}_common = {{ module.name }}_common.register({{ title }}EventService)({{ title }}EventService)
