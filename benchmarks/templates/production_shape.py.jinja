{% for hook in range(density) %}
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}Context, method_name='with_entry')({{ module.name }}_with_entry_hook_{{ hook }})
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}EntryReadContext, method_name='with_scoped_entry')({{ module.name }}_with_scoped_entry_hook_{{ hook }})
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}Context, method_name='with_event_scope')({{ module.name }}_with_event_scope_hook_{{ hook }})
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}EventContext, method_name='with_handler')({{ module.name }}_with_handler_hook_{{ hook }})
{% endfor %}
{% for index in range(density) %}
{% for hook in range(density) %}
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}Context, method_name='route_{{ index }}')({{ module.name }}_route_{{ index }}_hook_{{ hook }})
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}EntryReadContext, method_name='transition_{{ index }}')({{ module.name }}_transition_{{ index }}_hook_{{ hook }})
{% endfor %}
{% endfor %}
{% elif module.kind == 'scope' %}
{% for hook in range(density) %}
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}Context, method_name='with_scoped_entry')({{ module.name }}_with_scoped_entry_hook_{{ hook }})
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}Context, method_name='with_event_scope')({{ module.name }}_with_event_scope_hook_{{ hook }})
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}EventContext, method_name='with_handler')({{ module.name }}_with_handler_hook_{{ hook }})
{% endfor %}
{% endif %}
{% if module.extra_transition == 'flow' %}
{% for hook in range(density) %}
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}ScopedWriteContext, method_name='with_flow')(beta_with_flow_hook_{{ hook }})
{% endfor %}
{% elif module.extra_transition == 'worker' %}
{% for hook in range(density) %}
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook({{ title }}ScopedWriteContext, method_name='with_worker')(gamma_with_worker_hook_{{ hook }})
    {{ module.name }}_common = {{ module.name }}_common.register_method_hook(WorkerWriteContext, method_name='with_step')(gamma_with_step_hook_{{ hook }})
{% endfor %}
{% endif %}

    {{ module.name }}_write = RegistryBuilder().include({{ module.name }}_common)
    {{ module.name }}_write = {{ module.name }}_write.register({{ title }}WriteService)({{ title }}WriteService)
{% if module.kind in ['entry', 'scope'] %}
    {{ module.name }}_write = {{ module.name }}_write.register({{ title }}ScopeWriteService)({{ title }}ScopeWriteService)
{% endif %}
{% if module.extra_transition == 'flow' %}
    {{ module.name }}_write = {{ module.name }}_write.register(FlowService)(FlowService)
{% elif module.extra_transition == 'worker' %}
    {{ module.name }}_write = {{ module.name }}_write.register(WorkerService)(WorkerService)
    {{ module.name }}_write = {{ module.name }}_write.register(WorkerStepService)(WorkerStepService)
{% endif %}

    registry = registry.include({{ module.name }}_write, qualifiers=qual('{{ module.name }}') & qual('write'))
    registry = registry.include({{ module.name }}_common, qualifiers=qual('{{ module.name }}'))

{% endfor %}
    return registry


SCENARIO = {{ scenario | tojson }}
ACTIVE_MODULES = (
{% for module in active_module_names %}
    {{ module | tojson }},
{% endfor %}
)
assert ACTIVE_MODULES, 'Expected at least one benchmark module'
OUTPUT_VALUES = {'active_modules': ACTIVE_MODULES}
REGISTRY = build_registry().build()
TARGET = BenchmarkRoot


def invoke(root: BenchmarkRoot) -> None:
    app = root.app

{% for module in active_modules %}
{% if module.name == 'alpha' %}
    alpha_scope = app.with_alpha_context().route_0().transition_0()
    _ = alpha_scope.scope
    if SCENARIO == 'portable':
        alpha_scope_write = alpha_scope.with_scoped_write()
        _ = alpha_scope_write.scope_write
    else:
        _ = app.with_alpha_context().with_write().write

{% elif module.name == 'beta' %}
    if SCENARIO == 'portable':
        beta_scope_write = app.with_beta_context().route_0().transition_0().with_scoped_write()
        beta_flow = beta_scope_write.with_flow(1)
        _ = beta_flow.flow
    else:
        _ = app.with_beta_context().with_write().write

{% elif module.name == 'gamma' %}
    if SCENARIO == 'portable':
        gamma_scope_write = app.with_gamma_context().route_0().transition_0().with_scoped_write()
        gamma_step = gamma_scope_write.with_worker(1).with_step(1)
        _ = gamma_step.step
    else:
        _ = app.with_gamma_context().with_write().write

{% elif module.name == 'epsilon' %}
    epsilon_event = app.with_epsilon_context().with_event_scope(1, 'events', 1, 1, 1)
    _ = epsilon_event.event
    if SCENARIO == 'portable':
        epsilon_write = epsilon_event.with_handler()
        _ = epsilon_write.scope_write

{% elif module.name == 'delta' %}
    delta_write = app.with_delta_context().with_write()
    _ = delta_write.write

{% endif %}
{% endfor %}
