    {{ module.name }}_common = {{ module.name }}_common.register_method({{ title }}EventContext, {{ title }}EventContext.with_handler)({{ module.name }}_with_handler)
{% for index in range(density) %}
    {{ module.name }}_common = {{ module.name }}_common.register_method({{ title }}Context, {{ title }}Context.route_{{ index }})({{ module.name }}_route_{{ index }})
    {{ module.name }}_common = {{ module.name }}_common.register_method({{ title }}EntryReadContext, {{ title }}EntryReadContext.transition_{{ index }})({{ module.name }}_transition_{{ index }})
