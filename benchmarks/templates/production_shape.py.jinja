    {{ module.name }}_common = {{ module.name }}_common.register_method({{ title }}Context, {{ title }}Context.with_entry)({{ module.name }}_with_entry)
    {{ module.name }}_common = {{ module.name }}_common.register_method({{ title }}Context, {{ title }}Context.with_event_scope)({{ module.name }}_with_event_scope)
