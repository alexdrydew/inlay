{% macro render_params(params) -%}
{%- for param in params -%}
{{ param.name }}: {{ param.type }}{% if not loop.last %}, {% endif %}
{%- endfor -%}
{%- endmacro %}

{% macro render_class(spec) -%}
class {{ spec.name }}:
    def __init__({% if spec.params %}self, {{ render_params(spec.params) }}{% else %}self{% endif %}) -> None:
{% if spec.params %}
{% for param in spec.params %}
        self.{{ param.name }} = {{ param.name }}
{% endfor %}
{% else %}
        pass
{% endif %}

{% endmacro %}

{% macro render_typed_dict(spec) -%}
class {{ spec.name }}(TypedDict):
{% if spec.fields %}
{% for field in spec.fields %}
    {{ field.name }}: {{ field.type }}
{% endfor %}
{% else %}
    pass
{% endif %}

{% endmacro %}

{% macro render_method(method) -%}
def {{ method.name }}({% if method.params %}self, {{ render_params(method.params) }}{% else %}self{% endif %}) -> {{ method.return_type }}: ...
{%- endmacro %}

{% macro render_protocol(spec) -%}
class {{ spec.name }}(Protocol):
{% if spec.fields or spec.methods %}
{% for field in spec.fields %}
    {{ field.name }}: {{ field.type }}
{% endfor %}
{% for method in spec.methods %}
    {{ render_method(method) }}
{% endfor %}
{% else %}
    pass
{% endif %}

{% endmacro %}

{% macro render_function(spec) -%}
def {{ spec.name }}({{ render_params(spec.params) }}) -> {{ spec.return_type }}:
{% for line in spec.body %}
    {{ line }}
{% endfor %}

{% endmacro %}

from typing import Annotated, Protocol, TypedDict

from inlay import LazyRef, RegistryBuilder, qual

{% for class_spec in spec.class_specs %}
{{ render_class(class_spec) }}
{% endfor %}

{% for typed_dict_spec in spec.typed_dict_specs %}
{{ render_typed_dict(typed_dict_spec) }}
{% endfor %}

{% for protocol_spec in spec.protocol_specs %}
{{ render_protocol(protocol_spec) }}
{% endfor %}

{% for function_spec in spec.function_specs %}
{{ render_function(function_spec) }}
{% endfor %}

{% for registry in spec.registries %}
{{ registry.name }} = RegistryBuilder()
{% for class_name in registry.common_classes %}
{{ registry.name }} = {{ registry.name }}.register({{ class_name }})({{ class_name }})
{% endfor %}
{% for method in registry.methods %}
{{ registry.name }} = {{ registry.name }}.register_method({{ method.protocol_name }}, method_name='{{ method.method_name }}')({{ method.function_name }})
{% endfor %}
{% for hook in registry.hooks %}
{{ registry.name }} = {{ registry.name }}.register_method_hook({{ hook.protocol_name }}, method_name='{{ hook.method_name }}')({{ hook.function_name }})
{% endfor %}

{% endfor %}
REGISTRY_BUILDER = RegistryBuilder()
{% for class_name in spec.shared_classes %}
REGISTRY_BUILDER = REGISTRY_BUILDER.register({{ class_name }})({{ class_name }})
{% endfor %}
{% if spec.multi_track %}
{% for track in range(spec.track_count) %}
REGISTRY_BUILDER = REGISTRY_BUILDER.include(T{{ track }}_COMMON, qualifiers=qual('m{{ track }}'))
REGISTRY_BUILDER = REGISTRY_BUILDER.include(T{{ track }}_COMMON, qualifiers=qual('m{{ track }}') & qual('write'))
{% endfor %}
{% else %}
REGISTRY_BUILDER = REGISTRY_BUILDER.include(COMMON, qualifiers=qual('m0'))
REGISTRY_BUILDER = REGISTRY_BUILDER.include(COMMON, qualifiers=qual('m0') & qual('write'))
{% endif %}
REGISTRY = REGISTRY_BUILDER.build()
